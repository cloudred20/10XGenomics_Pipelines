pdac1
pdac1 <- NormalizeData(pdac1, normalization.method = "LogNormalize", scale.factor = 10000)
pdac1 <- FindVariableFeatures(pdac1, selection.method = "vst", nfeatures = 2000)
head(VariableFeatures(pdac1), 10)
pdac1 <- ScaleData(pdac1, features = rownames(pdac1))
pdac1 <- RunPCA(pdac1, features = VariableFeatures(object = pdac1))
VizDimLoadings(pdac1, dims = 1:2, reduction = "pca")
DimPlot(pdac1, reduction = "pca") + NoLegend()
DimHeatmap(pdac1, dims = 1:10, cells = 200, balanced = TRUE)
pbmc <- FindNeighbors(pbmc, dims = 1:9)
pdac1 <- FindNeighbors(pdac1, dims = 1:9)
pdac1 <- FindClusters(pdac1, resolution = 0.5)
pdac1 <- JackStraw(pdac1, num.replicate = 100, dims = 20)
pdac1 <- ScoreJackStraw(pdac1, dims = 1:20)
pdac1 <- JackStraw(pdac1, num.replicate = 100, dims = 20)
pdac1 <- ScoreJackStraw(pdac1, dims = 1:20)
JackStrawPlot(pdac1, dims = 1:20)
JackStrawPlot(pdac1, dims = 1:20)
ElbowPlot(pdac1)
DimPlot(pdac1, reduction = "umap")
pdac1 <- RunUMAP(pdac1, dims = 1:9)
DimPlot(pdac1, reduction = "umap")
DimPlot(pdac1, reduction = "pca") + NoLegend()
pdac1.markers <- FindAllMarkers(pdac1, only.pos = TRUE)
pdac1.markers %>%
group_by(cluster) %>%
dplyr::filter(avg_log2FC > 1)
View(pdac1.markers)
VlnPlot(pbmc, features = c("CDH6","CD8A", "TLR4", "MUC16"))
VlnPlot(pdac1, features = c("CDH6","CD8A", "TLR4", "MUC16"))
VlnPlot(pdac1, features = c("CDH6","BMX", "TLR4", "MUC16"))
VlnPlot(pdac1, features = c("CDH6","BMX", "TLR4", "MIA"))
VlnPlot(pdac1, features = c("CDH6","BMX", "TLR4", "MIA"), log = T)
FeaturePlot(pdac1, features = c("CDH6","BMX", "TLR4", "MIA"))
pdac1.markers %>%
group_by(cluster) %>%
dplyr::filter(avg_log2FC > 1) %>%
slice_head(n = 10) %>%
ungroup()
pdac1.markers %>%
group_by(cluster) %>%
dplyr::filter(avg_log2FC > 1) %>%
slice_head(n = 1) %>%
ungroup()
pdac1.markers %>%
group_by(cluster) %>%
dplyr::filter(avg_log2FC > 1) %>%
slice_max(order_by = avg_log2FC, n = 1) %>%
ungroup()
